{
  "name": "monitorage-independant-polio",
  "version": "0.1.0",
  "private": true,
  "description": "Dashboard web d'aide à la décision pour le monitorage indépendant de la campagne Polio (RDC).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "etl:refresh": "tsx scripts/refresh-cache.ts",
    "etl:introspect": "tsx scripts/introspect-schema.ts",
    "backfill:build": "tsx scripts/build-backfill.ts",
    "backfill:update": "tsx scripts/build-backfill.ts -- --update",
    "harmonize-monitors": "tsx scripts/harmonize-monitors.ts",
    "build:analytics": "tsx scripts/build-analytics-cache.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^17.4.2",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "leaflet.markercluster": "^1.5.3",
    "next": "14.2.13",
    "p-retry": "^6.2.0",
    "pptxgenjs": "^4.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-leaflet": "^4.2.1",
    "react-leaflet-cluster": "^2.1.0",
    "swr": "^2.2.5",
    "tailwind-merge": "^2.5.2",
    "topojson-client": "^3.1.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/leaflet.heat": "^0.2.4",
    "@types/leaflet.markercluster": "^1.5.4",
    "@types/node": "^20.16.10",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "@types/topojson-client": "^3.1.4",
    "@types/topojson-specification": "^1.0.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
