# ---------------------------------------------------------------
#  ODK Central / Aggregate / ONA API
# ---------------------------------------------------------------
#  Authentification par TOKEN (recommandé).
#  Si ODK_TOKEN est fourni, il est utilisé en priorité.
ODK_TOKEN=4df4f5e1aa19b0c47f872fb0f2cd0b482cdf45f8
ODK_BASE_URL=https://api.whonghub.org
#  Formulaire ménage Polio (4498).
ODK_HOUSEHOLDS_FORM_ID=4498
ODK_HOUSEHOLDS_FORM_URL=https://api.whonghub.org/api/v1/data/4498.json
#  Formulaire hors-ménage (inchangé : 4499).
ODK_OUTSIDE_FORM_ID=4499
ODK_OUTSIDE_FORM_URL=https://api.whonghub.org/api/v1/data/4499.json
#  Fallback Basic Auth (laissez vides si token OK)
ODK_USERNAME=
ODK_PASSWORD=

# ---------------------------------------------------------------
#  Campagne
# ---------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Polio Independent Monitoring Dashboard
CAMPAIGN_START_DATE=2026-05-23
# Si false (defaut) : plancher dur a CAMPAIGN_START_DATE — seules les
# soumissions datees du 23/05/2026 et au-dela sont affichees. Les test runs
# et saisies anticipees sont exclus.
# Si true : aucun plancher — le dashboard affiche TOUTES les soumissions,
# y compris celles anterieures a CAMPAIGN_START_DATE.
CAMPAIGN_INCLUDE_PRE_START=false
# Plafond dur de la periode de monitorage : aucune soumission datee apres
# cette date n'est affichee dans le dashboard.
MONITORING_END_DATE=2026-06-10

# ---------------------------------------------------------------
#  Cache serveur (secondes)
# ---------------------------------------------------------------
CACHE_TTL_SECONDS=300

# ---------------------------------------------------------------
#  Verrouillage global du dashboard (production)
# ---------------------------------------------------------------
#  Hash SHA-256 du code d'accès qui protège TOUT le dashboard
#  (sidebar, topbar et contenu). Si non défini, le code par défaut
#  est "mbombo-rrpolio-2026".
#  Pour générer le hash d'un nouveau code :
#    node -e "crypto.subtle.digest('SHA-256', new TextEncoder().encode('VOTRE_CODE')).then(h => console.log(Buffer.from(h).toString('hex')))"
NEXT_PUBLIC_SITE_PASSCODE_HASH=

# ---------------------------------------------------------------
#  Backfill GitHub (lecture des snapshots historiques en prod)
# ---------------------------------------------------------------
#  REQUIS si le repo est PRIVÉ : sans ce token, jsDelivr/raw renvoient
#  403/404 et le backfill n'est jamais chargé en production.
#  Créer un PAT (https://github.com/settings/personal-access-tokens) avec
#  permission "Contents: Read" sur ce repo, puis ajouter sur Vercel :
#    Settings → Environment Variables → GITHUB_TOKEN = github_pat_...
GITHUB_TOKEN=
